# Copy to .env and fill in. Never commit .env — it is gitignored.

# ── Wallets (node scripts/setup.js generates these) ───────────────────────────

# Seller receive wallets (public keys) — one per persona, so escrow always pays the
# consultancy that actually won the tender, not a shared address.
# Fund each at https://faucet.solana.com (GitHub sign-in; CLI/RPC airdrops are gated).
WALLET_WHITEHALL=
WALLET_INSIGHT=
WALLET_STRATFORD=

# Buyer keypair (base58 secret) — signs escrow deposit/release. Also fund it.
BUYER_KEYPAIR_B58=

SOLANA_RPC_URL=https://api.devnet.solana.com

# ── TenderNet knobs ────────────────────────────────────────────────────────────
# No LLM API key needed here — the buyer + 3 seller personas run as your own logged-in
# Claude Code sessions (see README Quick start), not scripted processes calling an LLM API.

BUYER_MAX_SOL=0.001              # budget cap for the tender
TRACE=                           # set to 1 to log coral_* calls + on-chain Explorer links

# ── Optional: examples/txodds (a separate, earlier World Cup demo track) ──────
# ANTHROPIC_API_KEY / OPENAI_API_KEY / LLM_PROVIDER / LLM_MODEL are only used there —
# see examples/txodds/README.md.
